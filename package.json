{
  "name": "live-quiz-game",
  "version": "1.0.0",
  "description": "Real-time Live Quiz Game with WebSocket",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "start": "npm run start --workspace=server",
    "start:server": "npm run start --workspace=server",
    "start:client": "npm run start --workspace=client",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "install:all": "npm install && npm install --workspace=server && npm install --workspace=client"
  },
  "keywords": [
    "websocket",
    "quiz",
    "game",
    "real-time"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0"
  }
}
